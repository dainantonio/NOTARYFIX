{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "$other": {
          ".validate": "newData.hasChildren(['createdAt']) || newData.exists() === false"
        }
      }
    },

    "profiles": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
        ".write": "auth != null && auth.uid === $uid",
        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$/)"
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "$other": {
          ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean() || newData.val() === null"
        }
      }
    },

    "sessions": {
      "$sessionId": {
        ".read": "auth != null && (data.child('ownerUid').val() === auth.uid || auth.token.admin === true)",
        ".write": "auth != null && (( !data.exists() && newData.child('ownerUid').val() === auth.uid) || (data.exists() && data.child('ownerUid').val() === auth.uid))",

        "ownerUid": {
          ".validate": "newData.isString() && (!data.exists() || newData.val() === data.val())"
        },
        "updatedAt": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": "newData.val() !== null"
        }
      }
    },

    "admin": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    }
  }
}
